{
  "name": "vali-storages",
  "version": "2.1.0",
  "description": "TypeScript browser storage library with AES-GCM encryption, TTL expiration, namespacing, cross-tab sync, batch operations, and a fully type-safe API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UBF21/Vali-Storages"
  },
  "keywords": [
    "localStorage",
    "sessionStorage",
    "storage",
    "encryption",
    "AES",
    "AES-GCM",
    "TTL",
    "expiration",
    "sliding-expiration",
    "namespace",
    "prefix",
    "cross-tab",
    "typed-storage",
    "browser-storage",
    "typescript"
  ],
  "author": "Felipe Rafael Montenegro Morriberon <teabajo_ubf@hotmail.com> (https://fm-portafolio.netlify.app/)",
  "license": "MIT",
  "homepage": "https://vali-storages-docs.netlify.app/",
  "bugs": {
    "url": "https://github.com/UBF21/Vali-Storages/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "typescript": "^5.5.4",
    "vitest": "^4.1.2"
  }
}
